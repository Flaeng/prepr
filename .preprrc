{
  "output": [
    "html",
    "md",
    "csv",
    "prompt"
  ],
  "outputFile": "reports/report.prepr",
  "threshold": 5,
  "includeExtensions": [],
  "excludeExtensions": [".json"],
  "ignorePaths": [
    "node_modules",
    "bin",
    "obj",
    ".git",
    ".prepr-cache",
    "prepr.Tests",
    "reports",
    "design"
  ],
  "verbosity": "normal",
  "highSeverityThreshold": 50,
  "mediumSeverityThreshold": 25,
  "maxDuplicates": null,
  "maxFileLines": {
    "*": 200
  },
  "maxIndentation": {
    "*": 4
  }
}